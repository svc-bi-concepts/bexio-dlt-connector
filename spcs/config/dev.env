ENV=dev
ENV_UPPER=DEV
# Existing landing database
DB_NAME=RAW
DB_NAME_LOWER=raw
# Platform schema (secrets, network rule, image repo, job service)
SCHEMA=BEXIO_SPCS
SCHEMA_LOWER=bexio_spcs
# dlt writes tables here (dataset name = Snowflake schema)
DATA_SCHEMA=BEXIO
WAREHOUSE=BEXIO_DLT_WH
COMPUTE_POOL=BEXIO_DLT_POOL
BEXIO_EAI=BEXIO_DLT_EAI
JOB_SERVICE=BEXIO_DLT_JOB
IMAGE_REPO=BEXIO_DLT_IMAGES
# Snowflake roles + service account (see sql/bootstrap_raw_account.sql)
DEPLOYER_ROLE=BEXIO_DLT_DEPLOYER
LOADER_ROLE=BEXIO_DLT_LOADER
OPERATOR_ROLE=BEXIO_DLT_OPERATOR
SVC_USER=SVC_BEXIO_DLT
# Snow CLI connection name (snow connection add ...)
SNOW_CONNECTION=bexio-dlt
BEXIO_DLT_DATASET_NAME=BEXIO
BEXIO_DLT_PIPELINE_NAME=bexio_pipeline
# Snowpipe REST (insertFiles): role grants in sql/snowpipe_grants.sql
SNOWPIPE_REST_ROLE=BEXIO_SNOWPIPE_REST
SNOWPIPE_REST_USER=SNOWPIPE_REST
# Required when using deploy_infra.sh --snowpipe: Snowflake account REST host (no https://)
# SNOWFLAKE_EGRESS_HOSTPORT=xy12345.eu-central-1.aws.snowflakecomputing.com:443
SNOWFLAKE_EGRESS_HOSTPORT=
