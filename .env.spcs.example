# Additional variables for SPCS deploy (add to your .env — never commit .env)

# Snowflake account identifier (region included), e.g. xy12345.eu-central-1
SNOWFLAKE_ACCOUNT=

# Optional override; default is ${SNOWFLAKE_ACCOUNT}.snowflakecomputing.com
# SNOWFLAKE_HOST=xy12345.eu-central-1.snowflakecomputing.com

# Service account created by spcs/sql/bootstrap_raw_account.sql
DLT_SNOWFLAKE_USER=SVC_BEXIO_DLT
DLT_SNOWFLAKE_PASSWORD=

# Snowpipe REST key (RSA PEM file path); used by ./spcs/create_secrets.sh (--snowpipe or add-on)
# SNOWPIPE_PRIVATE_KEY_PATH=snowpipe_rsa.pem

# Your human user that receives BEXIO_DLT_DEPLOYER (optional, for bootstrap SQL)
# DEPLOYER_USER=you@company.ch

# Bexio OAuth (see AUTHENTICATION.md)
BEXIO_CLIENT_ID=
BEXIO_CLIENT_SECRET=
BEXIO_REFRESH_TOKEN=
