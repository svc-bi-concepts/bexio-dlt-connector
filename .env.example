# Copy to .env and fill in (never commit .env).
# OAuth app: https://developer.bexio.com — redirect URI must match exactly.

BEXIO_CLIENT_ID=
BEXIO_CLIENT_SECRET=
BEXIO_REDIRECT_URI=http://127.0.0.1:8765/callback
# Optional; defaults to broad read scopes in oauth_login.py
# BEXIO_SCOPES=openid offline_access ...

# Prefer file for refresh-token rotation (see AUTHENTICATION.md)
BEXIO_REFRESH_TOKEN_FILE=./bexio_refresh_token
# BEXIO_REFRESH_TOKEN=

# dlt destination (local default)
BEXIO_DLT_DESTINATION=duckdb
BEXIO_DLT_DATASET_NAME=bexio
BEXIO_DLT_PIPELINE_NAME=bexio_pipeline
